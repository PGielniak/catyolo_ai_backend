# CatYolo Backend — copy to .env and fill in values

DATABASE_PATH=/mnt/ssd/home/patryk/pycharm/catyolo_ai_backend/catyolo.db
LOG_FILE_PATH=./var/log/catyolo/catyolo.log
LOG_LEVEL=INFO

# Camera credentials (fallback for the /frame endpoint)
CAMERA_USERNAME=
CAMERA_PASSWORD=

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be stable across restarts; changing it invalidates all existing API keys.
API_KEY_SALT=change-me-to-a-long-random-string

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3100

# WS2 — Multi-camera: max number of scenes (cameras) the backend will store.
# Create-scene requests beyond this cap are rejected with 409. Must match the
# worker's MAX_SCENES.
MAX_SCENES=3
